---
interface Props {
	title: string;
	body: string;
}

const { title, body } = Astro.props;
---

<div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-sm hover:shadow-md transition-shadow duration-300 p-6">
	<h2 class="text-xl font-semibold text-gray-900 dark:text-gray-100 mb-2">
		{title}
	</h2>
	<p class="text-gray-600 dark:text-gray-400 leading-relaxed">
		{body}
	</p>
</div>
