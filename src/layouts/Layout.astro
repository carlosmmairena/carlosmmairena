---
import Footer from '../components/organisms/Footer.astro';
import Header from '../components/organisms/Header.astro';

import "../styles/global.css";

interface Props {
	title: string;
	currentPath: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Carlos Mairena | Infraestructura, programación, ciberseguridad y más.." />
		<meta name="keywords" content="programación, ciberseguridad, monitoreo, hardening, tutoriales, carlos mairena, costa rica, guanacaste">
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content="v1.0" />
		<title>{title}</title>
	<script is:inline>
		(function() {
			const stored = localStorage.getItem('theme');
			const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
			if (stored === 'dark' || (!stored && prefersDark)) {
				document.documentElement.classList.add('dark');
			}
		})();
	</script>
	</head>
	<Header currentPath={Astro.props.currentPath} />
	<body class="font-sans bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100">
		<slot />
	</body>
	<Footer />
</html>
